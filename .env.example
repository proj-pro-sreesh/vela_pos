# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# For local MongoDB: mongodb://localhost:27017/vela-pos
# For MongoDB Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vela-pos
MONGODB_URI=mongodb://localhost:27017/vela-pos

# JWT Authentication (do not share)
JWT_SECRET=vela-pos-secret-key-change-in-production-2024

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Email Configuration (for password reset)
# Using Gmail SMTP - for production, use a proper email service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Vela POS <your-email@gmail.com>"
